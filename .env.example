# NAS mount paths (Unraid paths — change to match your setup)
NAS_PHOTOS_PATH=/mnt/user/appdata/ebaylister/photos
NAS_DB_PATH=/mnt/user/appdata/ebaylister/db

# Ollama — point this at your existing Ollama instance.
# Use host.docker.internal to reach Ollama running on the host machine.
# On Linux you may need to use your host's LAN IP instead (e.g. http://192.168.1.x:11434).
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5vl:7b

# eBay API credentials (optional — enables live price research)
EBAY_APP_ID=
EBAY_CLIENT_SECRET=

# Your server's IP or domain (used in CSV photo URLs)
# eBay needs to be able to fetch this URL from the internet.
# Options: port-forward port 8000, Cloudflare Tunnel, or Tailscale.
SERVER_BASE_URL=http://192.168.1.x:8000
