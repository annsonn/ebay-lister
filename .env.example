# Local paths for photos and database
NAS_PHOTOS_PATH=./data/photos
NAS_DB_PATH=./data/db

# Ollama — point this at your existing Ollama instance.
# Use host.docker.internal to reach Ollama running on the host machine (Docker Desktop).
# On Linux / Unraid use your server's LAN IP instead (e.g. http://192.168.1.x:11434).
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5vl:7b

# Photo hosting for CSV export (optional — leave blank to skip photo URLs in CSV).
# Set this when you're ready to publish listings. Must be a publicly accessible URL.
# Options: Cloudflare Tunnel, port-forward, Imgur/GDrive upload (future).
# SERVER_BASE_URL=https://your-tunnel.example.com
